<% layout('/layouts/boilerplate') %>
   <div class="row mt-3">
    <div class="col-8 offset-2">
    <h3>Edit your listing</h3>

    <form method="post" action="/listings/<%= listing._id %>?_method=PUT" 
         novalidate 
         class="needs-validation"
         enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required></div> 
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea></div>

        <div class="mb-3">
            <% if (originalImageurl) { %>
              <label class="form-label">Original Listing Image</label><br>
              <img src="<%= originalImageurl %>" alt="Listing image" class="img-fluid" style="max-width: 300px; margin-bottom: 1rem;"/>    
           <% } else { %>
              <p>No image uploaded for this listing.</p>
            <% } %>
        </div> 

        <div class="mb-3">
            <label for="image" class="form-label">Upload New Image</label>
          <input type="file" name="image"  class="form-control" >    
        </div> 
 
     <!-- CATEGORY DROPDOWN -->
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select name="listing[category]" class="form-select" required>
                    <option value="">-- Select Category --</option>
                    <option value="Trending"    <%= listing.category === "Trending"      ? "selected" : "" %>>🔥 Trending</option>
                    <option value="Rooms"       <%= listing.category === "Rooms"         ? "selected" : "" %>>🛏️ Rooms</option>
                    <option value="Farm"        <%= listing.category === "Farm"          ? "selected" : "" %>>🏡 Farm</option>
                    <option value="Iconic Cities" <%= listing.category === "Iconic Cities" ? "selected" : "" %>>🏙️ Iconic Cities</option>
                    <option value="Mountains"   <%= listing.category === "Mountains"     ? "selected" : "" %>>⛰️ Mountains</option>
                    <option value="Amazing Pools" <%= listing.category === "Amazing Pools" ? "selected" : "" %>>🏊 Amazing Pools</option>
                    <option value="Camping"     <%= listing.category === "Camping"       ? "selected" : "" %>>⛺ Camping</option>
                    <option value="Arctic"      <%= listing.category === "Arctic"        ? "selected" : "" %>>❄️ Arctic</option>
                    <option value="Hiking"      <%= listing.category === "Hiking"        ? "selected" : "" %>>🥾 Hiking</option>
                </select>
            </div>


 <div class="row">
        <div class="mb-3 col-md-4">

        <div class="mb-3">
            <label for="price" class="form-label">Price</label>
            <input type="text" name="listing[price]"  value="<%= listing.price %>" class="form-control" required></div>

              </div>
        <div class="mb-3 col-md-8">
        <div class="mb-3">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required></div>
 </div>
    </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]"  value="<%= listing.location %>" class="form-control" required></div>
      
        <button class="btn btn-dark editbtn">Edit Button</button>
    </form>
</div>
</div>
